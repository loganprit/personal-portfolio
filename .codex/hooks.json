{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$(git rev-parse --show-toplevel)/.codex/hooks/session-start-superpowers.sh\"'",
            "statusMessage": "loading superpowers startup context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$(git rev-parse --show-toplevel)/.codex/hooks/stop-checks.sh\"'",
            "timeout": 900,
            "statusMessage": "running lint and typecheck"
          }
        ]
      }
    ]
  }
}
