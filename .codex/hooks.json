{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'bash \"$(git rev-parse --show-toplevel)/.codex/hooks/stop-checks.sh\"'",
            "timeout": 900,
            "statusMessage": "running lint and typecheck"
          }
        ]
      }
    ]
  }
}
